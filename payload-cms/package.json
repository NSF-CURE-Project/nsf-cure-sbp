{
  "name": "nsf-cure-sbp",
  "version": "1.0.0",
  "description": "A blank template to get started with Payload 3.0",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "prebuild": "pnpm generate:types && pnpm generate:importmap",
    "build": "cross-env NODE_OPTIONS=\"--no-deprecation --max-old-space-size=8000\" next build",
    "dev": "cross-env NODE_OPTIONS=--no-deprecation next dev --turbopack -H admin.sbp.local -p 3000",
    "dev:webpack": "cross-env NODE_OPTIONS=--no-deprecation next dev -H admin.sbp.local -p 3000",
    "devsafe": "rm -rf .next && cross-env NODE_OPTIONS=--no-deprecation next dev --turbopack -H admin.sbp.local -p 3000",
    "generate:importmap": "cross-env NODE_OPTIONS=--no-deprecation payload generate:importmap",
    "generate:types": "cross-env NODE_OPTIONS=--no-deprecation payload generate:types",
    "lint": "cross-env NODE_OPTIONS=--no-deprecation next lint",
    "payload": "cross-env NODE_OPTIONS=--no-deprecation payload",
    "start": "cross-env NODE_OPTIONS=\"--no-deprecation --max-old-space-size=2048\" next start -H admin.sbp.local -p 3000",
    "test": "pnpm run test:int && pnpm run test:e2e",
    "publish:all": "cross-env NODE_OPTIONS=--no-deprecation payload script scripts/publish-all.ts",
    "test:e2e": "cross-env NODE_OPTIONS=\"--no-deprecation --no-experimental-strip-types\" pnpm exec playwright test",
    "test:int": "cross-env NODE_OPTIONS=--no-deprecation vitest run --config ./vitest.config.mts",
    "sync:admin-help": "cross-env NODE_OPTIONS=--no-deprecation payload run scripts/sync-admin-help-from-handbook.ts",
    "snapshot:reporting": "cross-env NODE_OPTIONS=--no-deprecation payload run scripts/create-reporting-snapshot.ts",
    "test:unit:node": "node --experimental-strip-types --test tests/unit-node/**/*.test.mjs",
    "seed:statics-example": "cross-env NODE_OPTIONS=--no-deprecation payload run src/seed/staticsFundamentalsExample.ts",
    "seed:engineering-library": "cross-env NODE_OPTIONS=--no-deprecation payload run src/seed/engineeringInteractiveLibrary.ts"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@payloadcms/db-postgres": "3.65.0",
    "@payloadcms/email-nodemailer": "^3.65.0",
    "@payloadcms/next": "3.65.0",
    "@payloadcms/richtext-lexical": "3.65.0",
    "@payloadcms/storage-s3": "3.65.0",
    "@payloadcms/ui": "3.65.0",
    "@react-pdf/renderer": "^4.3.1",
    "cross-env": "^7.0.3",
    "dotenv": "16.4.7",
    "graphql": "^16.8.1",
    "katex": "^0.16.22",
    "mathjs": "^15.1.1",
    "next": "15.5.12",
    "nodemailer": "^7.0.12",
    "payload": "3.65.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "sharp": "0.34.5"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.0.0",
    "@playwright/test": "1.56.1",
    "@testing-library/react": "16.3.0",
    "@types/node": "^22.5.4",
    "@types/react": "19.1.8",
    "@types/react-dom": "19.1.6",
    "@vitejs/plugin-react": "4.5.2",
    "autoprefixer": "^10.4.21",
    "eslint": "^9.16.0",
    "eslint-config-next": "15.5.12",
    "jsdom": "26.1.0",
    "playwright": "1.56.1",
    "playwright-core": "1.56.1",
    "postcss": "^8.5.6",
    "prettier": "^3.4.2",
    "tailwindcss": "^3.4.13",
    "typescript": "5.7.3",
    "vite-tsconfig-paths": "5.1.4",
    "vitest": "3.2.3"
  },
  "engines": {
    "node": "^18.20.2 || >=20.9.0",
    "pnpm": "^9 || ^10"
  },
  "pnpm": {
    "overrides": {
      "@img/sharp-libvips-darwin-arm64": "1.2.4"
    },
    "onlyBuiltDependencies": [
      "sharp",
      "esbuild",
      "unrs-resolver"
    ]
  }
}
