# ============================================================
# Payload CMS — environment template
# Copy to `.env` and fill in real values. Variables marked
# REQUIRED must be set for the CMS to boot. Everything else
# has a sensible fallback or is feature-gated.
# ============================================================

# ---------- Database (REQUIRED) ----------
# Postgres connection string. The CMS will fail to start without this.
DATABASE_URI=postgresql://sbp:sbp@localhost:5432/sbp

# ---------- Payload core (REQUIRED in production) ----------
# Encryption secret for sessions, tokens, etc. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
PAYLOAD_SECRET=
# Public URL the admin is reachable at (used in auth emails, cookies).
PAYLOAD_PUBLIC_SERVER_URL=http://localhost:3000
# Internal URL the CMS uses for server-to-server requests (defaults to
# PAYLOAD_PUBLIC_SERVER_URL). Override only if the admin sits behind a
# load balancer / different internal hostname than the public one.
PAYLOAD_INTERNAL_URL=

# ---------- Public URLs ----------
# The student-facing Next.js site (web/).
FRONTEND_URL=http://localhost:3001
WEB_PUBLIC_URL=http://localhost:3001
# Where the lesson live-preview iframe points. Usually same as FRONTEND_URL.
WEB_PREVIEW_URL=http://localhost:3001
NEXT_PUBLIC_SITE_URL=http://localhost:3001
# Shared secret stamped on draft preview links; must match web/.env.
PREVIEW_SECRET=

# ---------- Cookies & session ----------
PAYLOAD_COOKIE_PREFIX=payload
# Lax | Strict | None  (use None + Secure=true for cross-site staging).
PAYLOAD_COOKIE_SAMESITE=Lax
PAYLOAD_COOKIE_SECURE=false
# Optional: set when admin + web run on different subdomains so the
# session cookie is shared across them (e.g. ".cpp.edu").
PAYLOAD_APP_COOKIE_DOMAIN=
PAYLOAD_ADMIN_COOKIE_DOMAIN=

# ---------- Media storage (S3 or compatible) ----------
# Leave S3_BUCKET empty to use the local filesystem (good for dev).
# Setting S3_BUCKET enables the S3 plugin and uploads go to the bucket.
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_REGION=us-east-1
# Override for S3-compatible services (MinIO, R2, Spaces). Leave blank for AWS.
S3_ENDPOINT=
# Local fallback directory when S3 is disabled. Defaults to `media/`.
MEDIA_STATIC_DIR=

# ---------- Email: choose ONE adapter ----------
# Preferred: Resend. Set RESEND_API_KEY to enable.
RESEND_API_KEY=
RESEND_FROM="NSF CURE SBP <noreply@example.com>"
RESEND_API_BASE_URL=https://api.resend.com

# Self-hosted Resend Starter (only if you run your own relay).
RESEND_STARTER_URL=
RESEND_STARTER_SEND_URL=
RESEND_STARTER_AUTH_TOKEN=
RESEND_STARTER_TIMEOUT_MS=15000

# Fallback: SMTP. Used only if Resend is not configured.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="NSF CURE SBP <info@example.com>"
SMTP_SECURE=false
SMTP_CONNECTION_TIMEOUT_MS=10000
SMTP_GREETING_TIMEOUT_MS=10000
SMTP_SOCKET_TIMEOUT_MS=15000

# ---------- Email branding ----------
EMAIL_BRAND_NAME=NSF CURE SBP
EMAIL_PROGRAM_NAME=NSF CURE Summer Bridge Program
EMAIL_AWARD_LABEL=Supported by NSF Award #2318158
EMAIL_LOGO_URL=
SUPPORT_EMAIL=sbp-support@cpp.edu

# ---------- NSF reporting ----------
NSF_AWARD_NUMBER=2318158

# ---------- Feature flags ----------
# Async denormalization of class/chapter title cache. Set to "false"
# only for debugging — the sync path is slower and can stall saves.
PAYLOAD_ASYNC_CHAPTER_CLASS_SYNC=true
PAYLOAD_ASYNC_LESSON_CHAPTER_SYNC=true

# ---------- Runtime ----------
NODE_ENV=development
