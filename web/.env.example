# ==========================================================================
# Public-facing site URLs (browser-visible — must be safe to expose)
# ==========================================================================

# Origin of the Payload CMS (used by both server and browser).
NEXT_PUBLIC_CMS_URL=https://your-cms.up.railway.app

# Public origin of this Next.js app (used in canonical URLs, OG, sitemap).
NEXT_PUBLIC_SITE_URL=https://your-app.up.railway.app

# Optional alias for the web origin. Falls back to NEXT_PUBLIC_SITE_URL.
NEXT_PUBLIC_WEB_URL=

# Optional override for the Payload origin shown in browser code.
# Leave empty to inherit from NEXT_PUBLIC_CMS_URL.
NEXT_PUBLIC_PAYLOAD_URL=

# Optional override for the live-preview origin used by Payload's drafts UI.
NEXT_PUBLIC_PREVIEW_URL=

# ==========================================================================
# Server-only (must NOT be prefixed with NEXT_PUBLIC_)
# ==========================================================================

# Server-side target for /api/* rewrite to Payload. Required in production.
PAYLOAD_PROXY_TARGET=https://your-cms.up.railway.app

# Optional server-only Payload origin (used by payloadClient SSR fetches).
# Falls back to PAYLOAD_PROXY_TARGET / NEXT_PUBLIC_CMS_URL.
PAYLOAD_URL=

# Hard timeout for Payload SSR requests, in milliseconds. Default: 8000.
PAYLOAD_REQUEST_TIMEOUT_MS=8000

# When set to "1"/"true" the SSR layer treats Payload outages as soft-errors
# (renders empty data instead of 500). Use only for read-only public pages.
CMS_OPTIONAL_MODE=

# Shared secret for the Payload preview handshake. Required for live preview.
PREVIEW_SECRET=

# Hostname Payload preview links should target (defaults to the request host).
PREVIEW_HOST=

# When "1" the /api/preview endpoint accepts the secret via ?secret= query.
# Leave empty in production — preview should be cookie/header-only.
ALLOW_QUERY_PREVIEW=

# ==========================================================================
# Platform / runtime (set by Railway automatically — listed for reference)
# ==========================================================================

# Public domain Railway assigns to this service.
RAILWAY_PUBLIC_DOMAIN=
